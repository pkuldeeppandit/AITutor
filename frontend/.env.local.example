# Browser talks to the FastAPI app here (HTTP). /api/* routes on port 3000 proxy to this in dev.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000

# WebSocket STT connects directly to FastAPI (Next cannot proxy WS unless you use a custom server).
# If unset, the URL is derived from NEXT_PUBLIC_API_BASE, or falls back to ws://<this-host>:8000.
NEXT_PUBLIC_WS_BASE=ws://127.0.0.1:8000

